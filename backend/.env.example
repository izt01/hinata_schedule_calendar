# ══════════════════════════════════════
# ひなたカレンダー — 環境変数設定
# ══════════════════════════════════════

DATABASE_URL=YOUR_RAILWAY_POSTGRESQL_URL_HERE
JWT_SECRET=hinata_calendar_super_secret_key_2025
PORT=3000
FRONTEND_URL=http://localhost:8080

# ── メール通知（Gmail）──────────────────
# Googleアカウント → セキュリティ → アプリパスワードで生成
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASS=xxxxxxxxxxxxxxxxxxxx

# ── Webプッシュ通知（VAPID）────────────
# 以下のコマンドで生成: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_MAILTO=mailto:your-email@example.com
