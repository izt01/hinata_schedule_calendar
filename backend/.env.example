# ══════════════════════════════════════
# ひなたカレンダー — 環境変数設定
# Railway の PostgreSQL 接続情報をここに入力
# ══════════════════════════════════════

# RailwayのPostgreSQL接続URL
# 例: postgresql://postgres:password@monorail.proxy.rlwy.net:12345/railway
DATABASE_URL=YOUR_RAILWAY_POSTGRESQL_URL_HERE

# JWTシークレットキー（任意の長い文字列）
JWT_SECRET=hinata_calendar_super_secret_key_2025

# サーバーポート（Railwayは自動で設定するため通常不要）
PORT=3000

# フロントエンドのURL（CORS設定用）
# ローカル開発時は http://localhost:8080
# 本番は https://your-frontend-domain.com
FRONTEND_URL=http://localhost:8080
